from __future__ import annotations

import os
import re
from pathlib import Path
from typing import Any

import requests
from PIL import Image, ImageDraw

from .config import MEDIA_CACHE_DIR
from .models import RankedSignal


def _safe_name(text: str) -> str:
    return re.sub(r"[^a-zA-Z0-9_-]+", "_", text)[:80] or "image"


def _fallback_card(ranked: RankedSignal) -> str:
    path = MEDIA_CACHE_DIR / f"fallback_{_safe_name(ranked.topic.key)}.jpg"
    img = Image.new("RGB", (1280, 720), (245, 241, 232))
    draw = ImageDraw.Draw(img)
    title = ranked.topic.name
    signal_title = ranked.signal.title[:70]
    draw.rectangle((0, 0, 1280, 720), outline=(45, 45, 45), width=8)
    draw.text((80, 120), "Мир на ладони", fill=(30, 30, 30))
    draw.text((80, 260), title, fill=(30, 30, 30))
    draw.text((80, 360), signal_title, fill=(60, 60, 60))
    draw.text((80, 600), "туристическая редакция", fill=(90, 90, 90))
    img.save(path, quality=92)
    return str(path)


def select_media(ranked: RankedSignal, configs: dict[str, Any]) -> str | None:
    api_key = os.getenv("PEXELS_API_KEY", "").strip()
    if api_key:
        query = ranked.topic.name
        try:
            resp = requests.get(
                "https://api.pexels.com/v1/search",
                headers={"Authorization": api_key},
                params={"query": query, "orientation": "landscape", "per_page": 1},
                timeout=12,
            )
            if resp.ok:
                data = resp.json()
                photos = data.get("photos") or []
                if photos:
                    url = photos[0]["src"].get("large") or photos[0]["src"].get("original")
                    if url:
                        img_resp = requests.get(url, timeout=18)
                        img_resp.raise_for_status()
                        path = MEDIA_CACHE_DIR / f"pexels_{_safe_name(ranked.topic.key)}.jpg"
                        path.write_bytes(img_resp.content)
                        return str(path)
        except Exception:
            pass
    return _fallback_card(ranked)
