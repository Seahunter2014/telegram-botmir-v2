from __future__ import annotations

import re
from typing import Any

from .models import PostVariant

INTERNAL_WORDS = ["сигнал", "жанр", "source", "destination_post", "weekend_trip", "topic_hint", "cta_profile"]
MOJIBAKE_PATTERNS = ["\u0420\u045a", "\u0420\u045f", "\u0421\u0453", "\u0432\u0402"]


def check_text(text: str, configs: dict[str, Any]) -> list[str]:
    warnings: list[str] = []
    policy = configs["editorial_policy"]
    lower = text.lower()
    for phrase in policy.get("forbidden_phrases", []):
        if phrase.lower() in lower:
            warnings.append(f"запрещённая фраза: {phrase}")
    for word in INTERNAL_WORDS:
        if word.lower() in lower:
            warnings.append(f"внутреннее слово в публичном тексте: {word}")
    for pattern in MOJIBAKE_PATTERNS:
        if pattern in text:
            warnings.append(f"подозрение на битую кодировку: {pattern}")
    if len(text) < 450:
        warnings.append("слишком короткий текст")
    if len(text) > 3600:
        warnings.append("слишком длинный текст")
    paragraphs = [p for p in text.split("\n") if p.strip()]
    if len(paragraphs) < 4:
        warnings.append("мало абзацев для Telegram")
    starts = [p.strip().split(" ")[0].lower() for p in paragraphs if p.strip()]
    if len(starts) != len(set(starts)) and len(starts) > 4:
        warnings.append("повторяются начала абзацев")
    return warnings


def score_variant(variant: PostVariant, configs: dict[str, Any]) -> int:
    warnings = check_text(variant.text, configs)
    score = 100 - len(warnings) * 12
    if 700 <= len(variant.text) <= 2600:
        score += 10
    if "?" in variant.text:
        score += 3
    if re.search(r"\d", variant.text):
        score += 4
    return max(0, min(score, 115))


def clean_public_text(text: str) -> str:
    text = text.replace("travel-пост", "пост")
    text = text.replace("city-break", "короткая поездка")
    text = re.sub(r"\n{3,}", "\n\n", text).strip()
    return text
