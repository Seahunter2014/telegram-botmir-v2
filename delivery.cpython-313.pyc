from __future__ import annotations

from .config import load_all_configs
from .editor import generate_variants
from .links import buttons_for_topic
from .media import select_media
from .models import PostPackage
from .selector import rank_signals
from .sources import collect_signals


def build_package(topic_filter: str | None = None) -> PostPackage:
    configs = load_all_configs()
    signals = collect_signals(configs)
    ranked_items = rank_signals(signals, configs)
    if topic_filter:
        ranked_items = [item for item in ranked_items if item.topic.key == topic_filter or topic_filter.lower() in item.topic.name.lower()]
    if not ranked_items:
        raise RuntimeError("Не удалось найти подходящий свежий сигнал")
    ranked = ranked_items[0]
    variants = generate_variants(ranked, configs)
    buttons = buttons_for_topic(ranked.topic.key, configs)
    media_path = select_media(ranked, configs)
    warnings = []
    for variant in variants:
        warnings.extend([f"Вариант {variant.index}: {w}" for w in variant.risk_notes])
    return PostPackage(ranked=ranked, variants=variants, buttons=buttons, media_path=media_path, warnings=warnings)
