from __future__ import annotations

import json
import py_compile
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]

FORBIDDEN = [
    "Сигнал для weekend_trip",
    "\u0420\u045a",
    "\u0420\u045f",
    "\u0421\u0453",
    "\u0432\u0402",
]


def main() -> None:
    req = (ROOT / "requirements.txt").read_text(encoding="utf-8")
    assert "TELEGRAM_BOT_TOKEN" not in req
    assert all(" " not in line.strip() for line in req.splitlines() if line.strip()), "requirements должен быть построчно"
    for path in (ROOT / "configs").glob("*.json"):
        json.loads(path.read_text(encoding="utf-8-sig"))
    for path in (ROOT / "src").glob("*.py"):
        py_compile.compile(str(path), doraise=True)
    for path in ROOT.rglob("*"):
        if path.is_file() and path.name != "validate_project.py" and path.suffix in {".py", ".json", ".md", ".txt", ".example"}:
            text = path.read_text(encoding="utf-8", errors="replace")
            for phrase in FORBIDDEN:
                assert phrase not in text, f"Запрещённая фраза/кодировка {phrase!r} в {path}"
    print("OK: проект прошёл локальную проверку")


if __name__ == "__main__":
    main()
